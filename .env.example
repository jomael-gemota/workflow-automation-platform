OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PORT=
MONGODB_URI=
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:5173

# Google Workspace OAuth 2.0
# 1. Create a project at https://console.cloud.google.com
# 2. Enable Gmail, Drive, Docs, Sheets APIs
# 3. Create OAuth 2.0 credentials (Web Application type)
# 4. Add the redirect URI below to your Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# Slack OAuth 2.0
# 1. Create a Slack app at https://api.slack.com/apps
# 2. Add OAuth scopes: chat:write, im:write, files:write, conversations:history, channels:read, users:read
# 3. Add the redirect URI below to your Slack app settings
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/api/oauth/slack/callback

# Microsoft Teams OAuth 2.0 (via Microsoft Graph)
# 1. Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# 2. Add the redirect URI below under Authentication → Web → Redirect URIs
# 3. Grant API permissions: Team.ReadBasic.All, Channel.ReadBasic.All, ChannelMessage.Send,
#    ChannelMessage.Read.All, Chat.ReadWrite, User.ReadBasic.All (Delegated)
# 4. Create a client secret under Certificates & secrets
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TENANT_ID=common
TEAMS_REDIRECT_URI=http://localhost:3000/api/oauth/teams/callback